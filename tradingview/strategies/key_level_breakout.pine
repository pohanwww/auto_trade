// This Pine Script™ v6 strategy ports the Python "Key Level Breakout" system:
//   key_level_detector.py  → Swing Cluster, Pivot Points, Round Numbers,
//                            Session OHLC, Gap Analysis, Zone Merge
//   key_level_signal.py    → Breakout Long/Short with Instant Entry
//   key_level_strategy.py  → Opening Range filter, direction filter
//   position_manager.py    → Key Level ladder trailing stop, SL, force exit
//@version=6
strategy("Key Level Breakout",
     overlay              = true,
     pyramiding           = 0,
     default_qty_type     = strategy.fixed,
     default_qty_value    = 1,
     initial_capital      = 50000000,
     slippage             = 1,
     commission_type      = strategy.commission.cash_per_order,
     commission_value     = 0,
     calc_on_every_tick   = false,
     process_orders_on_close = true,
     max_bars_back        = 500,
     max_lines_count      = 500,
     max_labels_count     = 500)

// ═══════════════════════════════════════════════════════════════════════
//  INPUTS
// ═══════════════════════════════════════════════════════════════════════

GRP_MODE = "Strategy Mode"
i_direction    = input.string("both",  "Direction",               options = ["long", "short", "both"], group = GRP_MODE)
i_use_or       = input.bool(true,      "Use Opening Range Filter",                                    group = GRP_MODE)
i_use_breakout = input.bool(true,      "Enable Breakout Signals",                                     group = GRP_MODE)
i_use_bounce   = input.bool(false,     "Enable Bounce Signals",                                       group = GRP_MODE)
i_max_trades   = input.int(1,          "Max Trades / Day",        minval = 1, maxval = 10,            group = GRP_MODE)

GRP_OR = "Opening Range"
i_or_bars      = input.int(3,          "OR Bars",                 minval = 1, maxval = 20,            group = GRP_OR)

GRP_SESSION = "Session"
i_session_mode = input.string("day_only", "Session Mode", options = ["day_only", "day_night"],        group = GRP_SESSION)
i_ses_start_h  = input.int(8,          "Session Start Hour",      minval = 0, maxval = 23,            group = GRP_SESSION)
i_ses_start_m  = input.int(45,         "Session Start Minute",    minval = 0, maxval = 59,            group = GRP_SESSION)

GRP_KL = "Key Level Detection"
i_swing_period = input.int(10,         "Swing Lookback Period",   minval = 3,  maxval = 50,           group = GRP_KL)
i_cluster_tol  = input.float(50,       "Cluster Tolerance",       minval = 1,  maxval = 500,          group = GRP_KL)
i_zone_tol     = input.float(50,       "Zone Merge Tolerance",    minval = 1,  maxval = 500,          group = GRP_KL)
i_signal_count = input.int(7,          "Signal Level Count",      minval = 1,  maxval = 15,           group = GRP_KL)
i_round_scan   = input.float(500,      "Round Number Scan Range", minval = 50, maxval = 5000,         group = GRP_KL)
i_max_levels   = input.int(20,         "Max Total Levels",        minval = 5,  maxval = 40,           group = GRP_KL)

GRP_SIG = "Signal Detection"
i_brk_buffer   = input.float(0.3,      "Breakout Buffer (×ATR)",         minval = 0, maxval = 2, step = 0.05, group = GRP_SIG)
i_bnc_buffer   = input.float(0.3,      "Bounce Buffer (×ATR)",           minval = 0, maxval = 2, step = 0.05, group = GRP_SIG)
i_inst_thresh  = input.float(0.3,      "Instant Entry Threshold (×ATR)", minval = 0, maxval = 2, step = 0.05, group = GRP_SIG)
i_atr_period   = input.int(14,         "ATR Period",                     minval = 5, maxval = 50,              group = GRP_SIG)

GRP_RISK = "Risk Management"
i_sl_atr_mult  = input.float(1.0,      "SL ATR Multiplier (fallback)", minval = 0.5, maxval = 5, step = 0.1, group = GRP_RISK)
i_kl_buffer    = input.float(10,       "Key Level Buffer (points)",    minval = 0,   maxval = 200,            group = GRP_RISK)
i_trail_mode   = input.string("previous", "Trail Mode", options = ["current", "previous"],                    group = GRP_RISK)

GRP_VIS = "Visualization"
i_show_levels  = input.bool(true,      "Show Key Levels",   group = GRP_VIS)
i_show_or      = input.bool(true,      "Show OR High/Low",  group = GRP_VIS)
i_show_sl_ts   = input.bool(true,      "Show SL / TS Lines",group = GRP_VIS)

// ═══════════════════════════════════════════════════════════════════════
//  DERIVED SESSION CONSTANTS
// ═══════════════════════════════════════════════════════════════════════

int SES_START = i_ses_start_h * 60 + i_ses_start_m  // e.g. 525 for 08:45

int ENTRY_END   = i_session_mode == "day_night" ? 4 * 60 + 30  : 12 * 60 + 30
int SESSION_END = i_session_mode == "day_night" ? 5 * 60       : 13 * 60 + 45
int FORCE_EXIT  = i_session_mode == "day_night" ? 4 * 60 + 50  : 13 * 60 + 29
bool CROSSES_MIDNIGHT = i_session_mode == "day_night"

cur_min() =>
    hour * 60 + minute

// ═══════════════════════════════════════════════════════════════════════
//  PERSISTENT STATE
// ═══════════════════════════════════════════════════════════════════════

var int     lastDay       = -1
var int     tradesToday   = 0
var bool    orDone        = false
var int     orBarCnt      = 0
var float   orHigh        = na
var float   orLow         = na
var bool    levelsDone    = false

// Key levels (price, score)
var float[] klPrice       = array.new_float(0)
var float[] klScore       = array.new_float(0)

// Signal levels (top N for entry triggers)
var float[] sigPrice      = array.new_float(0)
var float[] sigScore      = array.new_float(0)

// Trailing levels (remaining levels for ladder TS)
var float[] trailLvls     = array.new_float(0)

// Position management
var int     nextKlIdx     = 0
var float   activeSL      = na
var float   activeTS      = na

// Drawing objects for daily key level / OR visualization
var line[]  dayLines      = array.new_line(0)
var label[] dayLabels     = array.new_label(0)
var bool    _prevLD       = false
var bool    _prevOrDone   = false

// Rolling swing accumulator (fed by ta.pivothigh / ta.pivotlow)
var float[] swingPrices   = array.new_float(0)
var int[]   swingBars     = array.new_int(0)

// Safe array access — PineScript ternary evaluates both branches,
// and `and` may not short-circuit in all contexts.
_sf(float[] arr, int i) =>
    float r = na
    if i >= 0 and i < array.size(arr)
        r := array.get(arr, i)
    r

_si(int[] arr, int i) =>
    int r = 0
    if i >= 0 and i < array.size(arr)
        r := array.get(arr, i)
    r

// ═══════════════════════════════════════════════════════════════════════
//  ROLLING SWING ACCUMULATION
// ═══════════════════════════════════════════════════════════════════════

float _sh = ta.pivothigh(high, i_swing_period, i_swing_period)
float _sl = ta.pivotlow(low,   i_swing_period, i_swing_period)

if not na(_sh)
    array.push(swingPrices, _sh)
    array.push(swingBars,   bar_index - i_swing_period)
if not na(_sl)
    array.push(swingPrices, _sl)
    array.push(swingBars,   bar_index - i_swing_period)

int MAX_SWINGS = 120
while array.size(swingPrices) > MAX_SWINGS
    array.shift(swingPrices)
    array.shift(swingBars)

// ═══════════════════════════════════════════════════════════════════════
//  DAY CHANGE DETECTION
// ═══════════════════════════════════════════════════════════════════════

int cm = cur_min()
int curDay = dayofmonth

bool newDay = curDay != lastDay
if newDay
    lastDay      := curDay
    tradesToday  := 0
    orDone       := false
    orBarCnt     := 0
    orHigh       := na
    orLow        := na
    levelsDone   := false
    nextKlIdx    := 0
    activeSL     := na
    activeTS     := na
    _prevLD      := false
    _prevOrDone  := false
    array.clear(klPrice)
    array.clear(klScore)
    array.clear(sigPrice)
    array.clear(sigScore)
    array.clear(trailLvls)
    while array.size(dayLines) > 0
        line.delete(array.pop(dayLines))
    while array.size(dayLabels) > 0
        label.delete(array.pop(dayLabels))

// ═══════════════════════════════════════════════════════════════════════
//  OPENING RANGE CALCULATION (B3)
// ═══════════════════════════════════════════════════════════════════════

bool inOrWindow = cm >= SES_START and not orDone

if inOrWindow
    if orBarCnt == 0
        orHigh := high
        orLow  := low
    else
        orHigh := math.max(orHigh, high)
        orLow  := math.min(orLow,  low)
    orBarCnt += 1
    if orBarCnt >= i_or_bars
        orDone := true

// ═══════════════════════════════════════════════════════════════════════
//  KEY LEVEL DETECTION — BUILD ONCE PER DAY  (B1)
// ═══════════════════════════════════════════════════════════════════════

// Previous daily OHLC via security (1-bar lag, no repaint)
[prevH, prevL, prevC, prevO] = request.security(syminfo.tickerid, "D",
     [high[1], low[1], close[1], open[1]], lookahead = barmerge.lookahead_on)

bool shouldCalcLevels = (i_use_or ? orDone : cm >= SES_START) and not levelsDone

if shouldCalcLevels
    // Temporary accumulator for raw levels (price, weight)
    float[] rawP = array.new_float(0)
    float[] rawW = array.new_float(0)

    // ── 1. Swing Clusters ──
    int _swSz = array.size(swingPrices)
    if _swSz > 0
        float[] sp = array.copy(swingPrices)
        array.sort(sp, order.ascending)
        int n = array.size(sp)

        float[] clAvg = array.new_float(0)
        int[]   clCnt = array.new_int(0)
        float   cSum  = _sf(sp, 0)
        int     cN    = 1

        if n > 1
            for i = 1 to n - 1
                float centroid = cSum / cN
                float px = _sf(sp, i)
                if na(px)
                    continue
                if math.abs(px - centroid) <= i_cluster_tol
                    cSum += px
                    cN   += 1
                else
                    array.push(clAvg, cSum / cN)
                    array.push(clCnt, cN)
                    cSum := px
                    cN   := 1
        if not na(cSum)
            array.push(clAvg, cSum / cN)
            array.push(clCnt, cN)

        int clSz = array.size(clAvg)
        if clSz > 0
            for i = 0 to clSz - 1
                float _ca = _sf(clAvg, i)
                int   _cc = _si(clCnt, i)
                if not na(_ca)
                    array.push(rawP, _ca)
                    array.push(rawW, 3.0 * _cc)

    // ── 2. Pivot Points ──
    if not na(prevH) and not na(prevL) and not na(prevC)
        float pp = (prevH + prevL + prevC) / 3.0
        array.push(rawP, pp)
        array.push(rawW, 1.0)
        array.push(rawP, 2 * pp - prevL)   // R1
        array.push(rawW, 1.0)
        array.push(rawP, 2 * pp - prevH)   // S1
        array.push(rawW, 1.0)
        array.push(rawP, pp + (prevH - prevL))  // R2
        array.push(rawW, 1.0)
        array.push(rawP, pp - (prevH - prevL))  // S2
        array.push(rawW, 1.0)

    // ── 3. Round Numbers ──
    float ref = na(open) ? prevC : open
    if not na(ref)
        float lo_rn = ref - i_round_scan
        float hi_rn = ref + i_round_scan
        float p_rn  = math.floor(lo_rn / 500.0) * 500.0
        while p_rn <= hi_rn
            if p_rn >= lo_rn
                if p_rn % 1000 == 0
                    array.push(rawP, p_rn)
                    array.push(rawW, 2.0)
                else if p_rn % 500 == 0
                    array.push(rawP, p_rn)
                    array.push(rawW, 1.5)
            p_rn += 500

    // ── 4. Gap Analysis ──
    if not na(prevC) and not na(open)
        float gap = math.abs(open - prevC)
        if gap >= 5
            float gw = math.min(gap / math.max(nz(orHigh - orLow, 1), 1.0), 2.0)
            array.push(rawP, prevC)
            array.push(rawW, gw)
            array.push(rawP, open)
            array.push(rawW, gw)

    // ── 5. Session OHLC ──
    if not na(prevH)
        array.push(rawP, prevH)
        array.push(rawW, 2.0)
    if not na(prevL)
        array.push(rawP, prevL)
        array.push(rawW, 2.0)
    if not na(prevC)
        array.push(rawP, prevC)
        array.push(rawW, 2.0)

    // ── Zone Merge ──
    int rawN = array.size(rawP)
    if rawN > 0
        // Sort rawP & rawW together by price ascending (bubble sort, safe for small N)
        if rawN > 1
            for i = 0 to rawN - 2
                for j = 0 to rawN - i - 2
                    float pj  = _sf(rawP, j)
                    float pj1 = _sf(rawP, j + 1)
                    if not na(pj) and not na(pj1) and pj > pj1
                        float tmpP = pj
                        float tmpW = _sf(rawW, j)
                        array.set(rawP, j,     pj1)
                        array.set(rawW, j,     _sf(rawW, j + 1))
                        array.set(rawP, j + 1, tmpP)
                        array.set(rawW, j + 1, nz(tmpW))

        // Merge sorted raw levels into zones
        float[] zPrice = array.new_float(0)
        float[] zScore = array.new_float(0)

        float z_sumP  = nz(_sf(rawP, 0))
        float z_sumW  = nz(_sf(rawW, 0))
        float z_bestP = z_sumP
        float z_bestW = z_sumW
        int   z_n     = 1

        if rawN > 1
            for i = 1 to rawN - 1
                float px = _sf(rawP, i)
                float wx = _sf(rawW, i)
                if na(px)
                    continue
                float centroid = z_sumP / z_n
                if math.abs(px - centroid) <= i_zone_tol
                    z_sumP  += px
                    z_sumW  += nz(wx)
                    z_n     += 1
                    if nz(wx) > z_bestW
                        z_bestP := px
                        z_bestW := nz(wx)
                else
                    array.push(zPrice, z_bestP)
                    array.push(zScore, z_sumW)
                    z_sumP  := px
                    z_sumW  := nz(wx)
                    z_bestP := px
                    z_bestW := nz(wx)
                    z_n     := 1
        array.push(zPrice, z_bestP)
        array.push(zScore, z_sumW)

        // Sort zones by score descending (bubble sort)
        int zN = array.size(zPrice)
        if zN > 1
            for i = 0 to zN - 2
                for j = 0 to zN - i - 2
                    float sj  = _sf(zScore, j)
                    float sj1 = _sf(zScore, j + 1)
                    if not na(sj) and not na(sj1) and sj < sj1
                        float tmpS = sj
                        float tmpP = _sf(zPrice, j)
                        array.set(zScore, j,     sj1)
                        array.set(zPrice, j,     _sf(zPrice, j + 1))
                        array.set(zScore, j + 1, tmpS)
                        array.set(zPrice, j + 1, nz(tmpP))

        // Store top i_max_levels as key levels
        int keep = math.min(zN, i_max_levels)
        array.clear(klPrice)
        array.clear(klScore)
        if keep > 0
            for i = 0 to keep - 1
                float _zp = _sf(zPrice, i)
                float _zs = _sf(zScore, i)
                if not na(_zp)
                    array.push(klPrice, _zp)
                    array.push(klScore, nz(_zs))

    levelsDone := true

// ═══════════════════════════════════════════════════════════════════════
//  SIGNAL DETECTION (B2)
// ═══════════════════════════════════════════════════════════════════════

float atrVal = ta.atr(i_atr_period)

bool inSession = false
if CROSSES_MIDNIGHT
    inSession := cm >= SES_START or cm < SESSION_END
else
    inSession := cm >= SES_START and cm < SESSION_END

bool inEntryWin = false
if CROSSES_MIDNIGHT
    inEntryWin := (ENTRY_END < SES_START) ? (cm >= SES_START or cm <= ENTRY_END) : (cm >= SES_START and cm <= ENTRY_END)
else
    inEntryWin := cm >= SES_START and cm <= ENTRY_END

bool canTrade = inSession and inEntryWin and levelsDone and
     (not i_use_or or orDone) and
     tradesToday < i_max_trades and
     not na(atrVal) and atrVal > 0 and
     array.size(klPrice) > 0

int   bestSigType  = 0      // 1 = brk_long, 2 = brk_short, 3 = bnc_long, 4 = bnc_short
float bestSigPrice = na
float bestSigScore = 0.0
float bestSigLevel = na

int sc = math.min(i_signal_count, array.size(klPrice))

if canTrade and strategy.position_size == 0 and sc > 0
    float bufBrk = atrVal * i_brk_buffer
    float bufBnc = atrVal * i_bnc_buffer
    float bufIns = atrVal * i_inst_thresh
    float prevCl = close[1]
    int klSz = array.size(klPrice)

    for i = 0 to sc - 1
        if i >= klSz
            break
        float level = _sf(klPrice, i)
        float scr   = _sf(klScore, i)
        if na(level)
            continue

        // ── Breakout long ──
        if i_use_breakout and close > level + bufBrk
            if na(prevCl) or prevCl <= level + bufBrk
                bool instant = high > level + bufIns and low <= level + bufBrk
                float ep = instant ? level + bufIns : close
                bool dirOk = i_direction != "short"
                bool orOk  = not i_use_or or not orDone or close >= orHigh
                if dirOk and orOk and scr > bestSigScore
                    bestSigType  := 1
                    bestSigPrice := ep
                    bestSigScore := scr
                    bestSigLevel := level
                continue

        // ── Breakout short ──
        if i_use_breakout and close < level - bufBrk
            if na(prevCl) or prevCl >= level - bufBrk
                bool instant_s = low < level - bufIns and high >= level - bufBrk
                float ep_s = instant_s ? level - bufIns : close
                bool dirOk_s = i_direction != "long"
                bool orOk_s  = not i_use_or or not orDone or close <= orLow
                if dirOk_s and orOk_s and scr > bestSigScore
                    bestSigType  := 2
                    bestSigPrice := ep_s
                    bestSigScore := scr
                    bestSigLevel := level
                continue

        // ── Bounce long ──
        if i_use_bounce and low <= level + bufBnc and close > level
            bool dirOk_bl = i_direction != "short"
            bool orOk_bl  = not i_use_or or not orDone or close >= orHigh
            if dirOk_bl and orOk_bl and scr > bestSigScore
                bestSigType  := 3
                bestSigPrice := close
                bestSigScore := scr
                bestSigLevel := level
            continue

        // ── Bounce short ──
        if i_use_bounce and high >= level - bufBnc and close < level
            bool dirOk_bs = i_direction != "long"
            bool orOk_bs  = not i_use_or or not orDone or close <= orLow
            if dirOk_bs and orOk_bs and scr > bestSigScore
                bestSigType  := 4
                bestSigPrice := close
                bestSigScore := scr
                bestSigLevel := level

// ═══════════════════════════════════════════════════════════════════════
//  ENTRY + STOP LOSS (B4)
// ═══════════════════════════════════════════════════════════════════════

if bestSigType != 0 and strategy.position_size == 0
    bool isLong   = bestSigType == 1 or bestSigType == 3
    bool isBounce = bestSigType >= 3

    // SL — key level on loss side (breakout) or bar extreme (bounce)
    float slPrice = na
    if isBounce
        slPrice := isLong ? low : high
    else
        // Find nearest key level on loss side
        int klN = array.size(klPrice)
        if isLong and klN > 0
            float bestBelow = na
            for i = 0 to klN - 1
                float p = _sf(klPrice, i)
                if not na(p) and p < bestSigLevel
                    if na(bestBelow) or p > bestBelow
                        bestBelow := p
            if not na(bestBelow)
                slPrice := bestBelow - i_kl_buffer
        else if not isLong and klN > 0
            float bestAbove = na
            for i = 0 to klN - 1
                float p = _sf(klPrice, i)
                if not na(p) and p > bestSigLevel
                    if na(bestAbove) or p < bestAbove
                        bestAbove := p
            if not na(bestAbove)
                slPrice := bestAbove + i_kl_buffer

    // Fallback SL: ATR-based
    if na(slPrice)
        slPrice := isLong ?
             bestSigPrice - atrVal * i_sl_atr_mult :
             bestSigPrice + atrVal * i_sl_atr_mult

    activeSL := slPrice

    // Build trailing levels — key levels on profit side beyond entry
    array.clear(trailLvls)
    int klN2 = array.size(klPrice)
    if sc < klN2
        for i = sc to klN2 - 1
            float lp = _sf(klPrice, i)
            if not na(lp)
                if isLong and lp > bestSigPrice
                    array.push(trailLvls, lp)
                else if not isLong and lp < bestSigPrice
                    array.push(trailLvls, lp)
    if isLong
        array.sort(trailLvls, order.ascending)
    else
        array.sort(trailLvls, order.descending)

    nextKlIdx := 0
    activeTS  := na
    tradesToday += 1

    if isLong
        strategy.entry("Long", strategy.long)
        strategy.exit("SL_Long", "Long", stop = slPrice)
    else
        strategy.entry("Short", strategy.short)
        strategy.exit("SL_Short", "Short", stop = slPrice)

// ═══════════════════════════════════════════════════════════════════════
//  KEY LEVEL LADDER TRAILING STOP (B4 cont.)
// ═══════════════════════════════════════════════════════════════════════

int trailSz = array.size(trailLvls)
if strategy.position_size != 0 and trailSz > 0
    bool isLongPos = strategy.position_size > 0
    float cp = close
    bool tsUpdated = false

    while nextKlIdx < trailSz
        float nxtLevel = _sf(trailLvls, nextKlIdx)
        if na(nxtLevel)
            break
        bool crossed = isLongPos ? cp > nxtLevel : cp < nxtLevel
        if crossed
            float stopP = na
            if i_trail_mode == "previous" and nextKlIdx > 0
                stopP := _sf(trailLvls, nextKlIdx - 1)
            else
                stopP := isLongPos ? nxtLevel - i_kl_buffer : nxtLevel + i_kl_buffer
            if na(activeTS) or (isLongPos and stopP > activeTS) or (not isLongPos and stopP < activeTS)
                activeTS  := stopP
                tsUpdated := true
            nextKlIdx += 1
        else
            break

    if tsUpdated
        float effStop = na
        if not na(activeTS)
            if isLongPos
                effStop := na(activeSL) ? activeTS : math.max(activeSL, activeTS)
            else
                effStop := na(activeSL) ? activeTS : math.min(activeSL, activeTS)
        else
            effStop := activeSL

        if not na(effStop)
            if isLongPos
                strategy.exit("TS_Long", "Long", stop = effStop)
            else
                strategy.exit("TS_Short", "Short", stop = effStop)

// ═══════════════════════════════════════════════════════════════════════
//  FORCE EXIT BY TIME (B4 cont.)
// ═══════════════════════════════════════════════════════════════════════

if strategy.position_size != 0 and cm >= FORCE_EXIT and inSession
    if strategy.position_size > 0
        strategy.close("Long", comment = "Force Exit")
    else
        strategy.close("Short", comment = "Force Exit")
    activeSL := na
    activeTS := na

// ═══════════════════════════════════════════════════════════════════════
//  RESET ON FLAT
// ═══════════════════════════════════════════════════════════════════════

if strategy.position_size == 0 and strategy.position_size[1] != 0
    activeSL  := na
    activeTS  := na
    nextKlIdx := 0

// ═══════════════════════════════════════════════════════════════════════
//  VISUALIZATION — Line-based daily Key Levels + OR
// ═══════════════════════════════════════════════════════════════════════

// Bars remaining in session (for line length)
int _sesMin = SESSION_END - SES_START
int _tfSec  = timeframe.in_seconds()
int _barsInSes = math.max(10, math.round(_sesMin * 60.0 / _tfSec))

// ── Draw OR lines when OR completes ──
bool _justOrDone = orDone and not _prevOrDone
_prevOrDone := orDone

if _justOrDone and i_show_or
    int _orEnd = bar_index + _barsInSes
    color _orC = color.new(#2196F3, 15)
    line _orHL = line.new(bar_index - i_or_bars, orHigh, _orEnd, orHigh, color = _orC, width = 2, style = line.style_solid)
    line _orLL = line.new(bar_index - i_or_bars, orLow,  _orEnd, orLow,  color = _orC, width = 2, style = line.style_dashed)
    array.push(dayLines, _orHL)
    array.push(dayLines, _orLL)
    label _orHLb = label.new(bar_index - i_or_bars, orHigh, "OR H " + str.tostring(orHigh, "#"), style = label.style_none, textcolor = _orC, size = size.small)
    label _orLLb = label.new(bar_index - i_or_bars, orLow,  "OR L " + str.tostring(orLow, "#"),  style = label.style_none, textcolor = _orC, size = size.small)
    array.push(dayLabels, _orHLb)
    array.push(dayLabels, _orLLb)

// ── Draw Key Level lines when levels are calculated ──
bool _justCalcLevels = levelsDone and not _prevLD
_prevLD := levelsDone

if _justCalcLevels and i_show_levels
    int _klSz = array.size(klPrice)
    int _sigCnt = math.min(i_signal_count, _klSz)
    int _lineEnd = bar_index + _barsInSes
    if _klSz > 0
        for _i = 0 to _klSz - 1
            float _p = _sf(klPrice, _i)
            float _s = _sf(klScore, _i)
            if not na(_p)
                bool _isSig = _i < _sigCnt
                color _c = _isSig ? color.new(#AB47BC, 15) : color.new(#9E9E9E, 50)
                int _w = _isSig ? 2 : 1
                line.style _ls = _isSig ? line.style_solid : line.style_dotted
                line _ln = line.new(bar_index, _p, _lineEnd, _p, color = _c, width = _w, style = _ls)
                array.push(dayLines, _ln)
                string _txt = str.tostring(_p, "#")
                if _isSig
                    _txt := "★ " + _txt + " (" + str.tostring(nz(_s), "#.#") + ")"
                label _lb = label.new(bar_index, _p, _txt, style = label.style_none, textcolor = _c, size = size.small)
                array.push(dayLabels, _lb)

// SL / TS lines (plot-based — these change every bar)
plot(i_show_sl_ts and strategy.position_size != 0 ? activeSL : na, "Stop Loss",     color = color.new(color.red,    20), linewidth = 1, style = plot.style_stepline)
plot(i_show_sl_ts and strategy.position_size != 0 ? activeTS : na, "Trailing Stop", color = color.new(color.orange, 20), linewidth = 2, style = plot.style_stepline)

// Entry markers
plotshape(bestSigType == 1 and strategy.position_size[1] == 0, "BRK Long",  style = shape.triangleup,   location = location.belowbar, color = color.green,  size = size.small)
plotshape(bestSigType == 2 and strategy.position_size[1] == 0, "BRK Short", style = shape.triangledown, location = location.abovebar, color = color.red,    size = size.small)
plotshape(bestSigType == 3 and strategy.position_size[1] == 0, "BNC Long",  style = shape.circle,       location = location.belowbar, color = color.lime,   size = size.tiny)
plotshape(bestSigType == 4 and strategy.position_size[1] == 0, "BNC Short", style = shape.circle,       location = location.abovebar, color = color.maroon, size = size.tiny)

// OR forming background
bgcolor(inOrWindow ? color.new(color.blue, 92) : na, title = "OR Window")

// ═══════════════════════════════════════════════════════════════════════
//  DEBUG
// ═══════════════════════════════════════════════════════════════════════

GRP_DBG = "Debug"
i_show_debug  = input.bool(false, "Show Debug", group = GRP_DBG)
i_force_test  = input.bool(false, "Force Test Trade (unconditional)", group = GRP_DBG)

// Force test: enter long on EVERY bar if flat — absolute minimum test
if i_force_test and strategy.position_size == 0
    strategy.entry("TestLong", strategy.long, qty = 1)

// Debug backgrounds — more opaque so they're visible on dark themes
bgcolor(i_show_debug and canTrade and strategy.position_size == 0 ? color.new(color.green, 75) : na, title = "DBG: canTrade")
bgcolor(i_show_debug and levelsDone and not canTrade and inSession ? color.new(color.red, 80) : na, title = "DBG: levels OK but blocked")

// Signal detected marker
plotshape(i_show_debug and bestSigType != 0, "DBG: Signal Detected", style = shape.diamond, location = location.abovebar, color = color.yellow, size = size.small)

// Condition breakdown — shows on chart AND data window
plot(i_show_debug ? cm : na, "DBG cm (08:45=525)", display = display.all)
plot(i_show_debug ? (canTrade ? 1 : 0) : na, "DBG canTrade", display = display.data_window)
plot(i_show_debug ? (inSession ? 1 : 0) : na, "DBG inSession", display = display.data_window)
plot(i_show_debug ? (inEntryWin ? 1 : 0) : na, "DBG inEntryWin", display = display.data_window)
plot(i_show_debug ? (levelsDone ? 1 : 0) : na, "DBG levelsDone", display = display.data_window)
plot(i_show_debug ? (orDone ? 1 : 0) : na, "DBG orDone", display = display.data_window)
plot(i_show_debug ? array.size(klPrice) : na, "DBG klCount", display = display.data_window)
plot(i_show_debug ? sc : na, "DBG sc", display = display.data_window)
plot(i_show_debug ? bestSigType : na, "DBG sigType", display = display.data_window)
plot(i_show_debug ? nz(atrVal) : na, "DBG ATR", display = display.data_window)
